# ─── IT Project Tracker — Configuration Docker ─────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs avant le premier démarrage.
# Ne jamais commiter le fichier .env en versioning.

# ── Obligatoire ────────────────────────────────────────────────────────────────

# Clé secrète JWT — générer avec : openssl rand -hex 64
JWT_SECRET=remplacer_par_un_secret_long_et_aleatoire_minimum_32_caracteres

# ── Ports ──────────────────────────────────────────────────────────────────────

# Port exposé sur la machine hôte (l'app tourne en interne sur 3000)
HOST_PORT=3000

# ── JWT ────────────────────────────────────────────────────────────────────────

# Durée de validité des tokens (ex : 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ── Compte administrateur (premier démarrage uniquement) ───────────────────────

SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_EMAIL=admin@example.com

# ── Option B uniquement — PostgreSQL ──────────────────────────────────────────
# (décommentez si vous utilisez docker-compose.pg.yml)

# POSTGRES_USER=tracker
# POSTGRES_PASSWORD=tracker_secret
# POSTGRES_DB=tracker
