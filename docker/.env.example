# ─── IT Project Tracker — Configuration Docker ─────────────────────────────────
# Copier ce fichier en .env et adapter les valeurs avant le premier démarrage.
# Ne jamais commiter le fichier .env en versioning.

# ── Obligatoire ────────────────────────────────────────────────────────────────

# Clé secrète JWT — générer avec : openssl rand -hex 64
JWT_SECRET=remplacer_par_un_secret_long_et_aleatoire_minimum_32_caracteres

# ── Ports ──────────────────────────────────────────────────────────────────────

# Port exposé sur la machine hôte (l'app tourne en interne sur 3000)
HOST_PORT=3000

# ── JWT ────────────────────────────────────────────────────────────────────────

# Durée de validité des tokens (ex : 7d, 24h, 30d)
JWT_EXPIRES_IN=7d

# ── Compte administrateur (premier démarrage uniquement) ───────────────────────

SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_EMAIL=admin@example.com

# ── LDAP / Active Directory ────────────────────────────────────────────────────

# URL du serveur LDAP (ldap:// ou ldaps:// pour TLS)
LDAP_URL=ldap://192.168.1.10:389

# Base DN de l'annuaire
LDAP_BASE_DN=DC=monentreprise,DC=local

# Compte de service (lecture seule) pour les recherches
LDAP_BIND_DN=CN=svc-gestion,OU=Services,DC=monentreprise,DC=local
LDAP_BIND_PASSWORD=motdepasse_service

# Base et filtre de recherche des utilisateurs
LDAP_USER_SEARCH_BASE=OU=Utilisateurs,DC=monentreprise,DC=local
LDAP_USER_SEARCH_FILTER=(sAMAccountName={{username}})

# false = accepter les certificats auto-signés (courant en réseau interne)
LDAP_TLS_REJECT_UNAUTHORIZED=false

# DN complet des groupes AD → services de l'application
LDAP_GROUP_DEV=CN=GRP-Dev,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_NETWORK=CN=GRP-Network,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_RH=CN=GRP-RH,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_DG=CN=GRP-Direction,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_TECH=CN=GRP-Tech,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_ACHATS=CN=GRP-Achats,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_ADMIN=CN=GRP-GProjet-Admin,OU=Groupes,DC=monentreprise,DC=local

# ── Option B uniquement — PostgreSQL ──────────────────────────────────────────
# (décommentez si vous utilisez docker-compose.pg.yml)

# POSTGRES_USER=tracker
# POSTGRES_PASSWORD=tracker_secret
# POSTGRES_DB=tracker
