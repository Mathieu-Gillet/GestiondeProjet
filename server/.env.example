NODE_ENV=development
PORT=3000

# Base de données (Option A - SQLite)
DB_PATH=./data/tracker.db

# Base de données (Option B - PostgreSQL)
# DATABASE_URL=postgresql://user:password@db:5432/tracker

# Authentification
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Compte admin initial (utilisé par db:seed)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_EMAIL=admin@example.com
