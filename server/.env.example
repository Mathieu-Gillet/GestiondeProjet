NODE_ENV=development
PORT=3000

# Base de données (Option A - SQLite)
DB_PATH=./data/tracker.db

# Base de données (Option B - PostgreSQL)
# DATABASE_URL=postgresql://user:password@db:5432/tracker

# Authentification JWT
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Compte admin initial (utilisé par db:seed)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_EMAIL=admin@example.com

# ─── Authentification LDAP / Active Directory ───────────────────────────────
# URL du serveur LDAP (ldap:// ou ldaps:// pour TLS)
LDAP_URL=ldap://192.168.1.10:389

# Base DN de l'annuaire
LDAP_BASE_DN=DC=monentreprise,DC=local

# Compte de service utilisé pour les recherches (lecture seule)
LDAP_BIND_DN=CN=svc-gestion,OU=Services,DC=monentreprise,DC=local
LDAP_BIND_PASSWORD=motdepasse_service

# Base de recherche des utilisateurs
LDAP_USER_SEARCH_BASE=OU=Utilisateurs,DC=monentreprise,DC=local

# Filtre de recherche — {{username}} est remplacé par la valeur saisie
# Active Directory : (sAMAccountName={{username}})
# OpenLDAP        : (uid={{username}})
LDAP_USER_SEARCH_FILTER=(sAMAccountName={{username}})

# Mettre à false pour accepter les certificats auto-signés (ldaps:// en interne)
LDAP_TLS_REJECT_UNAUTHORIZED=true

# ─── Mapping groupes LDAP → services ────────────────────────────────────────
# Renseigner le DN complet du groupe correspondant à chaque service
# Laisser vide si le service n'a pas de groupe dédié
LDAP_GROUP_DEV=CN=GRP-Dev,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_NETWORK=CN=GRP-Network,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_RH=CN=GRP-RH,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_DG=CN=GRP-Direction,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_TECH=CN=GRP-Tech,OU=Groupes,DC=monentreprise,DC=local
LDAP_GROUP_ACHATS=CN=GRP-Achats,OU=Groupes,DC=monentreprise,DC=local
# Groupe dont les membres reçoivent le rôle admin dans l'application
LDAP_GROUP_ADMIN=CN=GRP-GProjet-Admin,OU=Groupes,DC=monentreprise,DC=local
