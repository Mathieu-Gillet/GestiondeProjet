NODE_ENV=development
PORT=3000

# Base de données (Option A - SQLite)
DB_PATH=./data/tracker.db

# Base de données (Option B - PostgreSQL)
# DATABASE_URL=postgresql://user:password@db:5432/tracker

# Authentification
JWT_SECRET=change_me_in_production_use_a_long_random_string
JWT_EXPIRES_IN=7d

# Compte admin initial (utilisé par db:seed)
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=changeme
SEED_ADMIN_EMAIL=admin@example.com

# Microsoft Entra ID (Azure AD)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id-app-registration

# Object IDs des groupes Azure AD (un par service)
# Laisser vide si le service n'est pas encore configuré dans AD
AZURE_GROUP_DEV=
AZURE_GROUP_NETWORK=
AZURE_GROUP_RH=
AZURE_GROUP_DG=
AZURE_GROUP_TECH=
AZURE_GROUP_ACHATS=
AZURE_GROUP_ADMIN=
